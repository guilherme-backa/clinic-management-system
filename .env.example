# =============================================================================
# Clinic Management System — Configuração unificada
# Copie este arquivo para .env e ajuste os valores
# =============================================================================

# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development

# ─── Portas dos serviços ──────────────────────────────────────────────────────
BACKEND_PORT=3000
FRONTEND_PORT=3001
REDIS_PORT=6379
# Nexus usa portas fixas: 8081 (UI) e 8082 (Docker registry)

# ─── MySQL (rodando no HOST, fora do Docker) ──────────────────────────────────
# Dentro do container: host.docker.internal
# Dev local (fora do Docker): localhost
DB_HOST=host.docker.internal
DB_PORT=3306
DB_USER=clinic
DB_PASSWORD=clinic_pass
DB_NAME=clinic_db
DB_SSL=false

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=troque-por-um-segredo-longo-e-aleatorio
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=troque-por-outro-segredo-refresh
JWT_REFRESH_EXPIRES_IN=7d

# ─── Frontend (Next.js) ───────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3000/api/v1

# ─── Nexus / Docker Registry ──────────────────────────────────────────────────
NEXUS_URL=http://localhost:8081
DOCKER_REGISTRY=localhost:8082

# ─── Versões das imagens ──────────────────────────────────────────────────────
BACKEND_VERSION=latest
FRONTEND_VERSION=latest
